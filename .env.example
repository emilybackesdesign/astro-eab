# Web3Forms access key for the contact form (https://web3forms.com).
# Public client-side identifier (not a true secret), but env-driven so it isn't
# hardcoded in source. Set in this .env locally and in the Cloudflare Pages
# project's environment variables for production. The PUBLIC_ prefix is required
# for Astro to expose it to the client-rendered HTML.
PUBLIC_WEB3FORMS_KEY=
