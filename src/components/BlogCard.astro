---
interface Props {
  title: string;
  slug: string;
  date: Date;
  category: string;
  coverImage: string;
  excerpt?: string;
}
const { title, slug, date, category, coverImage, excerpt } = Astro.props;
const formattedDate = date.toLocaleDateString('en-US', { year: 'numeric', month: 'long' });
---
<a href={"/post/" + slug} class="blog-card" data-aos="fade-up">
  <div class="blog-card-image">
    <img src={coverImage} alt="" loading="lazy" decoding="async" />
  </div>
  <div class="blog-card-body">
    <div class="blog-card-meta">
      <span class="blog-category">{category}</span>
      <span class="blog-date">{formattedDate}</span>
    </div>
    <h4 class="blog-title">{title}</h4>
    {excerpt && <p class="blog-excerpt">{excerpt}</p>}
  </div>
</a>

<style>
  .blog-card {
    background: var(--card-bg-default);
    border-radius: 16px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    transition: background 0.2s, transform 0.2s;
  }
  .blog-card:hover { background: var(--elevated); transform: translateY(-2px); }
  .blog-card-image img { width: 100%; aspect-ratio: 16/9; object-fit: cover; display: block; }
  .blog-card-body { padding: 1.25rem; display: flex; flex-direction: column; gap: 0.5rem; }
  .blog-card-meta { display: flex; gap: 0.75rem; align-items: center; }
  .blog-category {
    font-family: 'Public Sans', sans-serif;
    font-size: var(--text-extra-sm);
    color: var(--toe-bean-pink-200);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border: 1px solid rgba(241,180,187,0.3);
    border-radius: 4px;
    padding: 2px 7px;
  }
  .blog-date {
    font-family: 'Public Sans', sans-serif;
    font-size: var(--text-extra-sm);
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .blog-title {
    font-family: 'Pridi', serif;
    font-size: var(--h5);
    color: var(--ink);
    margin: 0;
    line-height: 1.3;
    letter-spacing: 1px;
  }
  .blog-excerpt {
    font-family: 'Public Sans', sans-serif;
    font-size: var(--text-sm);
    color: var(--body);
    margin: 0.5rem 0 0;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
