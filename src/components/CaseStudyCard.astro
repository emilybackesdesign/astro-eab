---
interface Props {
  number: string;
  title: string;
  tags: string[];
  excerpt: string;
  slug: string;
  coverImage?: string;
}
const { number, title, tags, excerpt, slug, coverImage } = Astro.props;
const displayNum = number.replace('.', '');
---
<article class="cs-card">
  <div class="cs-content">
    <div class="cs-tags">
      {tags.map((tag) => <span class="cs-tag">{tag}</span>)}
    </div>
    <h3 class="cs-title">{title}</h3>
    <p class="cs-excerpt">{excerpt}</p>
    <a href={"/case-study/" + slug} class="cs-btn">EXPLORE CASE STUDY</a>
  </div>
  <div class="cs-visual">
    <span class="cs-ghost-num" aria-hidden="true">{displayNum}</span>
    {coverImage && (
      <div class="cs-mockup">
        <img src={coverImage} alt={title} loading="lazy" />
      </div>
    )}
  </div>
</article>

<style>
  .cs-card {
    background: var(--surface);
    border-radius: 16px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 360px;
    overflow: hidden;
    transition: background 0.2s, transform 0.2s;
  }
  .cs-card:hover {
    background: var(--elevated);
    transform: translateY(-2px);
  }

  /* ── Left: text content ── */
  .cs-content {
    padding: 2.5rem 2rem 2.5rem 2.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1rem;
  }
  .cs-tags { display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .cs-tag {
    font-family: 'Public Sans', sans-serif;
    font-size: 0.65rem;
    color: var(--body);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    background: var(--elevated);
    border-radius: 4px;
    padding: 3px 8px;
  }
  .cs-title {
    font-family: 'Pridi', serif;
    font-size: var(--h3);
    color: var(--ink);
    letter-spacing: 0.5px;
    line-height: 1.25;
    margin: 0;
  }
  .cs-excerpt {
    font-family: 'Public Sans', sans-serif;
    font-size: var(--text-sm);
    color: var(--body);
    line-height: 1.65;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .cs-btn {
    font-family: 'Public Sans', sans-serif;
    font-size: var(--text-extra-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #333;
    background: var(--toe-bean-pink-200);
    text-decoration: none;
    align-self: flex-start;
    padding: 9px 18px;
    border-radius: 4px;
    transition: background 0.15s;
    margin-top: 0.25rem;
  }
  .cs-btn:hover { background: var(--toe-bean-pink-400); }

  /* ── Right: visual with ghost numeral ── */
  .cs-visual {
    position: relative;
    background: var(--elevated);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 360px;
  }
  .cs-ghost-num {
    font-family: 'Pridi', serif;
    font-size: clamp(10rem, 16vw, 18rem);
    font-weight: 700;
    color: transparent;
    -webkit-text-stroke: 2px rgba(255, 255, 255, 0.1);
    line-height: 1;
    position: absolute;
    user-select: none;
    letter-spacing: -0.04em;
    pointer-events: none;
  }
  .cs-mockup {
    position: relative;
    z-index: 2;
    width: 78%;
    transform: rotate(-2.5deg);
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.55);
  }
  .cs-mockup img {
    width: 100%;
    display: block;
    aspect-ratio: 16 / 10;
    object-fit: cover;
  }

  @media (max-width: 700px) {
    .cs-card { grid-template-columns: 1fr; }
    .cs-visual { min-height: 220px; }
    .cs-ghost-num { font-size: 8rem; }
  }
</style>
