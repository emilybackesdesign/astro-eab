---
interface Props {
  number: string;
  slug: string;
  gif: string;
  tags: string[];
  title: string;
  titleHighlights?: string[];
  cta: string;
  body: string;
  index: number;
}
const {
  number,
  slug,
  gif,
  tags,
  title,
  titleHighlights = [],
  cta,
  body,
  index,
} = Astro.props;

// Digits only ("01"), with the dot rendered separately so it can be styled.
const digits = number.replace('.', '');

// Sticky offset: cards 1–3 pin at 12rem, then each later card steps down 4rem
// (→ 12 / 12 / 12 / 16 / 20rem) so the lower cards leave a visible ledge — a 1:1
// match of production's staggered sticky `top` values (192/192/192/256/320px).
const stickyTop = 12 + Math.max(0, index - 2) * 4;

// Split the title so any phrase in `titleHighlights` renders in the pink accent.
function escapeRegExp(s: string): string {
  return s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
}
const titleSegments = titleHighlights.length
  ? title
      .split(new RegExp(`(${titleHighlights.map(escapeRegExp).join('|')})`, 'g'))
      .filter((seg) => seg.length > 0)
      .map((seg) => ({ text: seg, accent: titleHighlights.includes(seg) }))
  : [{ text: title, accent: false }];
---
<article class="stack_card" style={`top:${stickyTop}rem`}>
  <div class="cs-content">
    <div class="cs-tags">
      {tags.map((tag) => <span class="cs-tag">{tag}</span>)}
    </div>
    <h3 class="cs-title">
      {titleSegments.map((seg) =>
        seg.accent ? <span class="accent">{seg.text}</span> : seg.text
      )}
    </h3>
    <p class="cs-body">{body}</p>
    <a href={"/case-study/" + slug} class="cs-btn">{cta}</a>
  </div>
  <div class="cs-visual">
    <p class="cs-num" aria-hidden="true" style={`background-image:url(${gif})`}>
      <span class="cs-num-dot">.</span>{digits}
    </p>
  </div>
</article>

<style>
  /* ── Sticky stacking shell (matches prod #282838 navy surface) ── */
  .stack_card {
    position: sticky;
    display: flex;
    flex-direction: row;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
    width: 100%;
    max-width: 1140px;
    margin: 0 auto;
    height: 24rem;
    padding: 0 2rem;
    background-color: #282838;
    border: 1px solid #373749;
    border-radius: 8px;
    overflow: hidden;
  }

  /* ── Left: text column ── */
  .cs-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    max-width: 50%;
    flex: 1 1 50%;
  }
  .cs-tags {
    display: flex;
    flex-wrap: wrap;
    margin-bottom: 16px;
  }
  .cs-tag {
    font-family: 'Public Sans', sans-serif;
    font-size: 0.7rem;
    font-weight: 400;
    line-height: 20px;
    color: #f1b4bb;
    text-transform: uppercase;
    background: rgba(55, 55, 73, 0.9);
    border: 1px solid #282838;
    border-radius: 8px;
    padding: 8px;
    margin: 0 4px 4px 0;
  }
  .cs-title {
    font-family: 'Pridi', serif;
    font-size: 1.725rem;
    font-weight: 600;
    line-height: 2.25rem;
    letter-spacing: 1px;
    color: #fffafa;
    margin: 0 0 16px;
  }
  .cs-title .accent {
    color: #f1b4bb;
  }
  .cs-body {
    font-family: 'Public Sans', sans-serif;
    font-size: 0.835rem;
    font-weight: 400;
    line-height: 20px;
    color: #fffafa;
    margin: 0 0 32px;
  }

  /* ── CTA button: navy text + hard offset shadow, press-into-shadow on hover ── */
  .cs-btn {
    align-self: flex-start;
    font-family: 'Public Sans', sans-serif;
    font-size: 0.75rem;
    font-weight: 400;
    line-height: 20px;
    text-transform: uppercase;
    letter-spacing: 2px;
    text-decoration: none;
    color: #1f4172;
    background-color: #f1b4bb;
    box-shadow: -4px 4px 0 0 #fffafa;
    border-radius: 4px;
    padding: 0.75rem 1.5rem;
    transition: 0.2s;
  }
  .cs-btn:hover {
    background-color: #c88f96;
    color: #fff;
    box-shadow: none;
    transform: translate(-4px, 4px);
  }

  /* ── Right: giant number with the project GIF clipped into the glyphs ── */
  .cs-visual {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
  }
  .cs-num {
    font-family: 'Pridi', serif;
    font-weight: 700;
    font-size: 18rem;
    line-height: 18rem;
    margin: 0;
    user-select: none;
    /* Fallback fill where background-clip:text is unsupported. */
    color: rgb(246, 218, 221);
    -webkit-text-fill-color: transparent;
    background-clip: text;
    -webkit-background-clip: text;
    background-repeat: repeat;
    background-size: 400px;
    background-position: 50% center;
  }
  .cs-num-dot {
    /* Inherits the same clip + gif fill as the digits. */
    font-family: 'Pridi', serif;
  }

  /* ── Responsive: sticky stacking is a desktop effect; stack on small screens ── */
  @media (max-width: 768px) {
    .stack_card {
      position: static;
      flex-direction: column;
      align-items: flex-start;
      height: auto;
      padding: 2rem;
      gap: 1.5rem;
    }
    .cs-content {
      max-width: 100%;
      flex: 1 1 auto;
    }
    .cs-visual {
      align-self: center;
    }
    .cs-num {
      font-size: 8rem;
      line-height: 8rem;
    }
  }
</style>
