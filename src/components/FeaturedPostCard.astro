---
interface Props {
  title: string;
  slug: string;
  date: Date;
  category: string;
  coverImage: string;
  excerpt?: string;
}
const { title, slug, date, category, coverImage, excerpt } = Astro.props;
const formattedDate = date.toLocaleDateString('en-US', { year: 'numeric', month: 'long' });
---
<a href={"/post/" + slug} class="featured-card" data-aos="fade-up">
  <div class="featured-card-image">
    <img src={coverImage} alt={title} loading="eager" />
    <span class="featured-flag">Latest</span>
  </div>
  <div class="featured-card-body">
    <div class="featured-card-meta">
      <span class="featured-category">{category}</span>
      <span class="featured-date">{formattedDate}</span>
    </div>
    <h2 class="featured-title">{title}</h2>
    {excerpt && <p class="featured-excerpt">{excerpt}</p>}
    <span class="featured-readmore">Read the post <span aria-hidden="true">&rarr;</span></span>
  </div>
</a>

<style>
  .featured-card {
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    background: var(--surface);
    border-radius: var(--radius-lg, 16px);
    overflow: hidden;
    text-decoration: none;
    transition: background 0.25s cubic-bezier(0.22, 1, 0.36, 1),
                transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .featured-card:hover { background: var(--elevated); transform: translateY(-3px); }

  .featured-card-image {
    position: relative;
    overflow: hidden;
    min-height: 100%;
  }
  .featured-card-image img {
    width: 100%;
    height: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    display: block;
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .featured-card:hover .featured-card-image img { transform: scale(1.04); }

  .featured-flag {
    position: absolute;
    top: 1rem;
    left: 1rem;
    font-family: 'Public Sans', sans-serif;
    font-size: var(--text-extra-sm);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #333;
    background: var(--toe-bean-pink-200);
    padding: 4px 10px;
    border-radius: 4px;
  }

  .featured-card-body {
    padding: clamp(1.5rem, 3vw, 2.75rem);
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.9rem;
  }
  .featured-card-meta { display: flex; gap: 0.75rem; align-items: center; }
  .featured-category {
    font-family: 'Public Sans', sans-serif;
    font-size: var(--text-extra-sm);
    color: var(--toe-bean-pink-200);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border: 1px solid rgba(241, 180, 187, 0.3);
    border-radius: 4px;
    padding: 2px 7px;
  }
  .featured-date {
    font-family: 'Public Sans', sans-serif;
    font-size: var(--text-extra-sm);
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .featured-title {
    font-family: 'Pridi', serif;
    font-size: var(--h3);
    color: var(--ink);
    margin: 0;
    line-height: 1.2;
    letter-spacing: 0.5px;
    text-wrap: balance;
  }
  .featured-excerpt {
    font-family: 'Public Sans', sans-serif;
    font-size: var(--text-body);
    color: var(--body);
    margin: 0;
    line-height: 1.6;
    max-width: 60ch;
    text-wrap: pretty;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .featured-readmore {
    font-family: 'Public Sans', sans-serif;
    font-size: var(--text-sm);
    color: var(--toe-bean-pink-200);
    margin-top: 0.25rem;
  }
  .featured-readmore span {
    display: inline-block;
    transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .featured-card:hover .featured-readmore span { transform: translateX(4px); }

  @media (max-width: 720px) {
    .featured-card { grid-template-columns: 1fr; }
    .featured-card-image img { aspect-ratio: 16 / 9; }
    .featured-title { font-size: var(--h4); }
  }

  @media (prefers-reduced-motion: reduce) {
    .featured-card,
    .featured-card-image img,
    .featured-readmore span { transition: none; }
    .featured-card:hover { transform: none; }
    .featured-card:hover .featured-card-image img { transform: none; }
    .featured-card:hover .featured-readmore span { transform: none; }
  }
</style>
