---
import { getPageTheme, type PageTheme } from '../lib/page-theme';

interface Props {
  /** Override the auto-detected theme if a page needs to force light/dark. */
  theme?: PageTheme;
}
const theme: PageTheme = Astro.props.theme ?? getPageTheme(Astro.url.pathname);
// The footer card is dark in both themes, so use the light wordmark; the light
// pages historically shipped eb_logo2.svg.
const logoSrc = theme === 'light' ? '/assets/images/eb_logo2.svg' : '/assets/images/eb_logo_navy_500.svg';
// Keep the copyright year current automatically (rendered at build time).
const year = new Date().getFullYear();
---
<footer class="site-footer" data-theme={theme}>
  <div class="footer-wrap">
    <div class="footer-card">
      <a href="/" class="footer-logo" aria-label="Emily Backes Design — home">
        <img src={logoSrc} alt="EB Design" height="56" decoding="async" />
      </a>
      <nav class="footer-nav" aria-label="Footer navigation">
        <div class="footer-col">
          <span class="footer-col-head">EXPLORE</span>
          <a href="/the-5-pillars-of-emily" class="footer-link">5 Pillars</a>
          <a href="/resume" class="footer-link">Resume</a>
          <a href="/experimental/ui-list" class="footer-link">Experiments</a>
        </div>
        <div class="footer-col">
          <span class="footer-col-head">STUFF</span>
          <a href="/legal/terms-conditions" class="footer-link">Terms &amp; Conditions</a>
          <a href="/legal/privacy-policy" class="footer-link">Privacy Policy</a>
          <a href="/legal/credits" class="footer-link">Credits</a>
        </div>
      </nav>
    </div>
    <p class="footer-copy">Copyright &copy; {year} | <strong>Proudly Crafted in Colorado</strong></p>
  </div>
</footer>

<style>
  /* ── Base (dark theme) ───────────────────────────────────────────────── */
  .site-footer {
    background: var(--bg);
    padding: 2.5rem 1.5rem 3rem;
  }
  .footer-wrap {
    max-width: 1180px;
    margin: 0 auto;
  }
  .footer-card {
    background: var(--surface);
    border-radius: 16px;
    padding: 2.5rem 3rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 3rem;
  }
  .footer-logo img { display: block; }
  .footer-nav {
    display: flex;
    gap: 4rem;
  }
  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }
  .footer-col-head {
    font-family: 'Public Sans', sans-serif;
    font-size: var(--text-extra-sm);
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-weight: 700;
    margin-bottom: 0.2rem;
  }
  .footer-link {
    font-family: 'Public Sans', sans-serif;
    font-size: var(--text-sm);
    color: var(--body);
    text-decoration: none;
    transition: color 0.15s;
  }
  .footer-link:hover { color: var(--toe-bean-pink-200); }
  .footer-copy {
    font-family: 'Public Sans', sans-serif;
    font-size: var(--text-extra-sm);
    color: var(--muted); /* --subtle (#76777d) failed WCAG AA on the dark footer (4.19:1) */
    text-align: center;
    margin: 1.25rem 0 0;
    letter-spacing: 0.06em;
  }
  .footer-copy strong { font-weight: 700; }

  /* ── Light theme (Toe Bean Pink pages) — dark card on the light page ───── */
  .site-footer[data-theme="light"] {
    background: transparent;
    padding: 4rem 2rem 1rem;
  }
  .site-footer[data-theme="light"] .footer-wrap { max-width: 1140px; }
  .site-footer[data-theme="light"] .footer-card {
    background: var(--card-bg-default);
    border-radius: var(--radius-md);
  }
  .site-footer[data-theme="light"] .footer-logo img { width: 115px; height: auto; }
  .site-footer[data-theme="light"] .footer-col-head { color: var(--snow); }
  .site-footer[data-theme="light"] .footer-link { color: var(--snow); }
  .site-footer[data-theme="light"] .footer-link:hover { color: var(--toe-bean-pink-200); }
  .site-footer[data-theme="light"] .footer-copy { color: var(--midnight-blue-500); }

  @media (max-width: 640px) {
    .footer-card {
      flex-direction: column;
      text-align: center;
      padding: 2rem 1.5rem;
    }
    .footer-nav { justify-content: center; gap: 2.5rem; }
  }
</style>
