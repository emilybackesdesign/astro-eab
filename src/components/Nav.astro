---
import { getPageTheme, type PageTheme } from '../lib/page-theme';

interface Props {
  /** Override the auto-detected theme if a page needs to force light/dark. */
  theme?: PageTheme;
}
const currentPath = Astro.url.pathname;
const theme: PageTheme = Astro.props.theme ?? getPageTheme(currentPath);
const isLight = theme === 'light';
---
<nav class="site-nav" data-theme={theme} role="navigation" aria-label="Main navigation">
  <div class="nav-inner">
    <a href="/" class="nav-logo" aria-label="Emily Backes Design home">
      <img src="/assets/images/eb_logo_navy_500.svg" alt="EB Design" decoding="async" />
    </a>
    <button class="nav-hamburger" aria-label="Open menu" aria-expanded="false" id="nav-toggle">
      <span></span><span></span><span></span>
    </button>
    <div class="nav-links" id="nav-links">
      <button class="nav-close" aria-label="Close menu" id="nav-close">&#x2715;</button>
      <a href="/about" class="nav-link" aria-current={currentPath === '/about' ? 'page' : undefined}>About</a>
      <a href="/#case-study-section" class="nav-link">Case Studies</a>
      <a href="/posts" class="nav-link" aria-current={currentPath.startsWith('/posts') || currentPath.startsWith('/post/') ? 'page' : undefined}>Journal</a>
      <a href="/contact" class="nav-cta">{isLight ? 'contact me' : 'Let’s Connect'}</a>
    </div>
  </div>
</nav>

<style>
  /* ── Base: frosted-glass floating bar (dark theme defaults) ──────────── */
  .site-nav {
    position: sticky;
    top: 1rem;
    z-index: 100;
    padding: 0 1rem;
  }
  .nav-inner {
    max-width: 1140px;
    margin: 0 auto;
    padding: 2rem 1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: rgba(26, 28, 35, 0.6);
    border-radius: var(--radius-md);
    -webkit-backdrop-filter: blur(1rem);
    backdrop-filter: blur(1rem);
  }
  .nav-logo img { display: block; height: 40px; width: auto; }
  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }
  .nav-link {
    font-family: 'Public Sans', sans-serif;
    font-size: 1rem;
    color: var(--ink);
    text-decoration: none;
    padding: 5px 8px;
    border: 1.5px solid transparent;
    border-radius: 4px;
    transition: color 0.15s, background 0.15s, border-color 0.15s;
  }
  /* Unified hover + active state — identical in both themes: navy text on a
     pink-200 pill. The pill is opaque so contrast no longer depends on the page
     background; the navy border delineates the chip on pink surfaces (the
     /about body and the light mobile menu) where the fill would otherwise blend. */
  .nav-link:hover,
  .nav-link[aria-current="page"] {
    color: var(--navy-blue-500);
    background: var(--toe-bean-pink-200);
    border-color: var(--navy-blue-500);
  }
  .nav-cta {
    font-family: 'Public Sans', sans-serif;
    font-size: 0.694rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--navy-blue-500);
    background: var(--toe-bean-pink-200);
    text-decoration: none;
    padding: 9px 15px;
    border-radius: 4px;
    margin-left: 0.5rem;
    box-shadow: -4px 4px 0 0 var(--bg);
    transition: all 0.2s;
  }
  .nav-cta:hover {
    /* Keep the pink-200 fill (navy text → 5.8:1); the press-in motion is the
       hover feedback. The old pink-400 fill dropped contrast to 3.8:1. */
    box-shadow: none;
    transform: translate(-4px, 4px);
  }
  .nav-hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }
  .nav-hamburger span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--ink);
    border-radius: var(--radius-xs);
    transition: transform 0.2s, opacity 0.2s;
  }
  .nav-close {
    display: none;
    background: none;
    border: none;
    color: var(--ink);
    font-size: 1.5rem;
    cursor: pointer;
    position: absolute;
    top: 1rem;
    right: 1.5rem;
  }

  /* ── Light theme (Toe Bean Pink pages) — transparent blurred bar ──────── */
  .site-nav[data-theme="light"] {
    top: 1rem;
    background: transparent;
    border-bottom: none;
    padding: 0 1rem;
  }
  .site-nav[data-theme="light"] .nav-inner {
    max-width: 1140px;
    padding: 2rem 1rem;
    background: transparent;
    border: none;
    border-radius: var(--radius-sm);
  }
  .site-nav[data-theme="light"] .nav-logo img { width: 103px; height: auto; }
  .site-nav[data-theme="light"] .nav-link {
    color: var(--navy-blue-500);
    letter-spacing: 0.25px;
    margin: 0 4px;
  }
  /* Hover/active is the shared base rule (navy text on pink-200 pill) — the
     light theme only needs to set the rest-state link color below. */
  .site-nav[data-theme="light"] .nav-cta {
    font-weight: 400;
    letter-spacing: 2px;
    color: var(--snow);
    background: var(--navy-blue-500);
    padding: 0.75rem 1.5rem;
    box-shadow: -4px 4px 0 0 var(--snow);
    transition: all 0.2s;
  }
  .site-nav[data-theme="light"] .nav-cta:hover {
    box-shadow: none;
    transform: translate(-4px, 4px);
    background: var(--navy-blue-500);
    color: var(--white);
  }
  .site-nav[data-theme="light"] .nav-hamburger span { background: var(--navy-blue-500); }
  .site-nav[data-theme="light"] .nav-close { color: var(--navy-blue-500); }

  /* ── Mobile ──────────────────────────────────────────────────────────── */
  @media (max-width: 991px) {
    .nav-hamburger { display: flex; }
    .nav-links {
      display: none;
      position: fixed;
      inset: 0;
      background: var(--bg);
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 2rem;
      z-index: 200;
    }
    .nav-links.nav--open { display: flex; }
    .nav-close { display: block; }
    .nav-link { font-size: 1.5rem; padding: 8px 16px; }
    .nav-cta { font-size: 1rem; padding: 12px 24px; margin-left: 0; }

    .site-nav[data-theme="light"] .nav-links { background: var(--toe-bean-pink-200); gap: 1.5rem; }
    .site-nav[data-theme="light"] .nav-link { color: var(--navy-blue-500); }
  }
</style>

<script>
  const toggle = document.getElementById('nav-toggle');
  const links = document.getElementById('nav-links');
  const close = document.getElementById('nav-close');
  toggle?.addEventListener('click', () => {
    links?.classList.toggle('nav--open');
    const expanded = links?.classList.contains('nav--open');
    toggle.setAttribute('aria-expanded', String(expanded));
  });
  close?.addEventListener('click', () => {
    links?.classList.remove('nav--open');
    toggle?.setAttribute('aria-expanded', 'false');
  });
</script>
