---
const photos = [
  { src: '/assets/images/em_fishing.webp', alt: 'Emily fishing' },
  { src: '/assets/images/marfa_2020.webp', alt: 'Marfa Prada store' },
  { src: '/assets/images/flower_cake.webp', alt: 'Custom flower cake' },
  { src: '/assets/images/2009_CU_grad.webp', alt: 'CU graduation' },
  { src: '/assets/images/2022_Denver.webp', alt: 'Denver 2022' },
];
---
<div class="polaroid-carousel" aria-label="Photo carousel">
  {photos.map((photo, i) => (
    <div class={"polaroid polaroid-" + i}>
      <img src={photo.src} alt={photo.alt} loading="lazy" />
    </div>
  ))}
</div>

<style>
  .polaroid-carousel {
    position: relative;
    width: 260px;
    height: 300px;
    margin: 0 auto;
  }
  .polaroid {
    position: absolute;
    inset: 0;
    background: white;
    padding: 10px 10px 32px;
    border-radius: 2px;
    box-shadow: 0 4px 24px rgba(0,0,0,0.4);
    animation: polaroid-cycle 15s ease-in-out infinite;
    opacity: 0;
  }
  .polaroid img {
    width: 100%;
    height: 220px;
    object-fit: cover;
    display: block;
  }
  .polaroid-0 { transform: rotate(-3deg); animation-delay: 0s; }
  .polaroid-1 { transform: rotate(2deg); animation-delay: 3s; }
  .polaroid-2 { transform: rotate(-1deg); animation-delay: 6s; }
  .polaroid-3 { transform: rotate(3.5deg); animation-delay: 9s; }
  .polaroid-4 { transform: rotate(-2deg); animation-delay: 12s; }
  @keyframes polaroid-cycle {
    0%, 15% { opacity: 1; z-index: 5; }
    20%, 100% { opacity: 0; z-index: 1; }
  }
  @media (prefers-reduced-motion: reduce) {
    .polaroid { animation: none; opacity: 1; }
    .polaroid-0 { z-index: 5; }
  }
</style>
