---
---
<div class="rotate-warning" role="alert" aria-live="polite">
  <lord-icon
    src="/assets/icons/lottie/system-regular-15-ratio.json"
    trigger="loop"
    style="width: 32px; height: 32px;"
  ></lord-icon>
  <p>For the best experience, please view this case study on a wider screen or rotate your device to landscape.</p>
</div>

<style>
  .rotate-warning {
    display: none;
    background: var(--surface);
    border-bottom: 1px solid var(--rule);
    padding: 0.75rem 1.5rem;
    gap: 0.75rem;
    align-items: center;
    text-align: left;
  }
  .rotate-warning p {
    font-family: 'Public Sans', sans-serif;
    font-size: var(--text-sm);
    color: var(--body);
    margin: 0;
  }
  @media (max-width: 900px) {
    .rotate-warning { display: flex; }
  }
</style>
