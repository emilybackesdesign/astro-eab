---
interface Props {
  name: string;
  jobTitle: string;
  quote: string | string[];
  avatarSrc?: string;
  featured?: boolean;
}
const { name, jobTitle, quote, avatarSrc, featured = false } = Astro.props;
const initials = name.split(' ').map(n => n[0]).join('').slice(0, 2);
const paragraphs = Array.isArray(quote) ? quote : [quote];
---
<article class:list={["testimonial", { featured }]}>
  <header class="testimonial-head">
    <div class="testimonial-avatar">
      {avatarSrc
        ? <img src={avatarSrc} alt={name} loading="lazy" decoding="async" />
        : <span class="avatar-initials">{initials}</span>
      }
    </div>
    <div class="testimonial-person">
      <span class="testimonial-name">{name}</span>
      <span class="testimonial-job">{jobTitle}</span>
    </div>
  </header>
  <div class="testimonial-quote">
    {paragraphs.map((p) => <p>{p}</p>)}
  </div>
</article>

<style>
  .testimonial {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  /* Avatar + name/title header row */
  .testimonial-head {
    display: flex;
    align-items: center;
    gap: 0.85rem;
  }
  .testimonial-avatar {
    width: 48px;
    height: 48px;
    border-radius: 100%;
    overflow: hidden;
    flex-shrink: 0;
    background: var(--elevated);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .testimonial-avatar img { width: 100%; height: 100%; object-fit: cover; }
  .avatar-initials {
    font-family: 'Public Sans', sans-serif;
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--toe-bean-pink-200);
  }
  .testimonial-person { display: flex; flex-direction: column; gap: 0.15rem; }
  .testimonial-name {
    font-family: 'Public Sans', sans-serif;
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--ink);
  }
  .testimonial-job {
    font-family: 'Public Sans', sans-serif;
    font-size: var(--text-extra-sm);
    color: var(--navy-blue-300);
  }

  /* Quote body */
  .testimonial-quote {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .testimonial-quote p {
    font-family: 'Public Sans', sans-serif;
    font-size: var(--text-sm);
    color: var(--muted);
    line-height: 1.7;
    margin: 0;
  }
  .featured .testimonial-quote p {
    font-size: 1.05rem;
  }
</style>
