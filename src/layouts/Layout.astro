---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  /** Per-page <body> background (light Webflow-port pages). Applied inline so it
      beats global.css's dark `body { background: var(--bg) }` regardless of dev-vs-build
      stylesheet order — a plain page-level `body{}` rule loses that race in `astro dev`. */
  bodyBg?: string;
  /** Load only the two design-system families (Pridi + Public Sans) instead of the
      full 8-family Webflow-port set. Opt-in for lean pages (e.g. blog posts). */
  leanFonts?: boolean;
  /** OpenGraph type — 'website' (default) or 'article' for blog posts. */
  ogType?: string;
  /** ISO timestamp for article:published_time (blog posts only). */
  publishedTime?: string;
  /** Author name for article:author (blog posts only). */
  author?: string;
}

const {
  title = 'Emily Backes — Product Designer',
  description = 'Portfolio of Emily Backes, Product Designer — UX, AI, and product design work.',
  ogImage = '/assets/images/og-eb-logo.png',
  bodyBg,
  leanFonts = false,
  ogType = 'website',
  publishedTime,
  author,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
const ogImageURL = new URL(ogImage, Astro.site).href;
const isHome = Astro.url.pathname === '/';

// JSON-LD for the homepage: WebSite + Person (E-E-A-T / entity signals).
const homeJsonLd = isHome
  ? {
      '@context': 'https://schema.org',
      '@graph': [
        {
          '@type': 'WebSite',
          name: 'Emily Backes',
          url: Astro.site?.href,
        },
        {
          '@type': 'Person',
          name: 'Emily Backes',
          jobTitle: 'Senior Product Designer',
          url: Astro.site?.href,
        },
      ],
    }
  : null;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {author && <meta property="article:author" content={author} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    {leanFonts ? (
      <link href="https://fonts.googleapis.com/css2?family=Pridi:wght@400;600&family=Public+Sans:ital,wght@0,400;0,500;0,700;1,400&display=swap" rel="stylesheet" />
    ) : (
      <link href="https://fonts.googleapis.com/css2?family=Pridi:wght@400;600&family=Public+Sans:ital,wght@0,400;0,500;0,700;1,400&family=Lato:wght@400;700;900&family=Josefin+Sans:wght@400;600;700&family=Roboto+Slab:wght@400;500;600;700;800&family=Just+Me+Again+Down+Here&family=Lexend:wght@400;500;600;700&family=Inconsolata:wght@400;500;600&display=swap" rel="stylesheet" />
    )}
    {homeJsonLd && <script type="application/ld+json" set:html={JSON.stringify(homeJsonLd)} />}
  </head>
  <body style={bodyBg ? `background:${bodyBg}` : undefined}>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <slot />
  </body>
</html>
<style>
  .skip-link {
    position: absolute;
    top: -100%;
    left: 0;
    background: var(--toe-bean-pink-200);
    color: var(--navy-blue-500);
    padding: 0.5rem 1rem;
    font-family: 'Public Sans', sans-serif;
    font-weight: 700;
    font-size: 0.875rem;
    z-index: 9999;
    text-decoration: none;
  }
  .skip-link:focus {
    top: 0;
  }
</style>
