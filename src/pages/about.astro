  }

  @media (prefers-reduced-motion: reduce) {
    .pl-track { animation: none; }
  }
</style>

<script>
  // Timeline scroll-progress white fill (mirrors prod's white progress line)
  const track = document.querySelector('.pl-tl-track');
  const fill = document.getElementById('pl-tl-fill');
  if (track && fill) {
    const onScroll = () => {
      const rect = (track as HTMLElement).getBoundingClientRect();
      const vh = window.innerHeight;
      const total = rect.height;
      const progressed = Math.min(Math.max(vh / 2 - rect.top, 0), total);
      (fill as HTMLElement).style.height = progressed + 'px';
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
  }
</script>

<script>
  // Lottie / lord-icon for the Quick Facts icons
  import { defineElement } from '@lordicon/element';
  import lottie from 'lottie-web';
  // @ts-ignore — @lordicon/element v2 type defs incorrectly declare 0 params
  defineElement(lottie.loadAnimation);
</script>
