<script>
  import lottie from 'lottie-web';
  const init = () => {
    document.querySelectorAll<HTMLElement>('[data-animation-type="lottie"]').forEach((el) => {
      if (el.dataset.lottieInit) return;
      const path = el.getAttribute('data-src');
      if (!path) return;
      el.dataset.lottieInit = '1';
      lottie.loadAnimation({
        container: el,
        renderer: (el.getAttribute('data-renderer') || 'svg') as 'svg' | 'canvas' | 'html',
        loop: el.getAttribute('data-loop') !== '0',
        autoplay: el.getAttribute('data-autoplay') !== '0',
        path,
      });
    });
  };
  if (document.readyState !== 'loading') init();
  else document.addEventListener('DOMContentLoaded', init);
</script>
