    text:'#1f2937',muted:'#9ca3af',dim:'#6b7280',
    blue:'#0d4798',blueBg:'#edf2fb',blueBdr:'#7fa8d4',
  };
  const data=[
    {m:'Nov',y:'2024',s:0,z:17,a:83},{m:'Dec',y:'2024',s:0,z:17,a:83},
    {m:'Jan',y:'2025',s:0,z:14,a:86},{m:'Feb',y:'2025',s:0,z:15,a:85},
    {m:'Mar',y:'2025',s:0,z:13,a:87},{m:'Apr',y:'2025',s:0,z:24,a:76},
    {m:'May',y:'2025',s:0,z:24,a:76},{m:'Jun',y:'2025',s:0,z:22,a:78},
    {m:'Jul',y:'2025',s:0,z:26,a:74},{m:'Aug',y:'2025',s:0,z:29,a:71},
    {m:'Sep',y:'2025',s:0,z:26,a:74},{m:'Oct',y:'2025',s:0,z:27,a:71},
    {m:'Nov',y:'2025',s:46,z:12,a:42},{m:'Dec',y:'2025',s:51,z:9,a:40},
    {m:'Jan',y:'2026',s:41,z:4,a:55,retired:true},
  ];
  const svg=document.getElementById('chart-channel');
  svg.setAttribute('viewBox',`0 0 ${W} ${H}`);
  svg.setAttribute('height',H);
  function mk(t,a,txt){const e=document.createElementNS(NS,t);for(const[k,v]of Object.entries(a))e.setAttribute(k,v);if(txt!==undefined)e.textContent=txt;return e;}
  function tx(x,y,s,{fill=C.text,size=12,weight=400,anchor='start'}={}){return mk('text',{x,y,fill,'font-size':size,'font-weight':weight,'text-anchor':anchor,'font-family':"-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif"},s);}
  svg.appendChild(mk('rect',{width:W,height:H,fill:'#fff'}));
  [0,25,50,75,100].forEach(p=>{
    const gy=YB-p*SCALE;
    svg.appendChild(mk('line',{x1:ML,y1:gy,x2:W-MR,y2:gy,stroke:p===0?C.axis:C.grid,'stroke-width':1}));
    svg.appendChild(tx(ML-8,gy+4,p+'%',{fill:C.muted,size:10,anchor:'end'}));
  });
  svg.appendChild(tx(ML,26,'Solves by Channel',{size:15,weight:600}));
  svg.appendChild(tx(ML,45,'Ticket resolution shift across Sage Bot, ZD Bot, and human agents',{fill:C.muted,size:11}));
  const LEG=[{l:'Sage Bot',c:C.sage},{l:'ZD Bot',c:C.zd,s:'#2d4200'},{l:'Agent',c:C.agent,s:'#c2d4dc'}];
  let lx=W-MR-228;
  LEG.forEach(i=>{svg.appendChild(mk('rect',{x:lx,y:20,width:10,height:10,rx:2,fill:i.c,stroke:i.s||'none','stroke-width':1}));svg.appendChild(tx(lx+14,29,i.l,{fill:C.dim,size:11}));lx+=78;});
  const bi=12,bx0=Math.round(BX0+bi*STEP)-9,bx1=Math.round(BX0+14*STEP+BAR_W)+9;
  svg.appendChild(mk('rect',{x:bx0,y:MT-12,width:bx1-bx0,height:YB-(MT-12)+4,fill:'none',stroke:C.sage,'stroke-width':1.5,'stroke-dasharray':'6,4',rx:8}));
  const bcx=bx0+(bx1-bx0)/2,bw=130,bh=18,by=MT-35;
  svg.appendChild(mk('rect',{x:bcx-65,y:by,width:bw,height:bh,rx:9,fill:C.sageBg,stroke:C.sage,'stroke-width':1}));
  svg.appendChild(tx(bcx-8,by+12.5,'Sage Bot launches',{fill:C.sage,size:9.5,weight:600,anchor:'middle'}));
  const ax=bcx+55,ay=by+bh/2;
  svg.appendChild(mk('polygon',{points:`${ax},${ay} ${ax-6},${ay-4} ${ax-6},${ay+4}`,fill:C.sage}));
  data.forEach((d,i)=>{
    const bx=BX0+i*STEP,cx=bx+BAR_W/2;
    const aH=d.a*SCALE,aY=YB-aH;
    svg.appendChild(mk('rect',{x:bx,y:aY,width:BAR_W,height:aH,fill:C.agent,rx:2}));
    if(aH>=12)svg.appendChild(tx(cx,aY+aH/2+4,d.a+'%',{fill:C.agentT,size:10,weight:600,anchor:'middle'}));
    if(d.z>0){const zH=d.z*SCALE,zY=YB-(d.a+d.z)*SCALE;svg.appendChild(mk('rect',{x:bx,y:zY,width:BAR_W,height:zH,fill:C.zd,rx:2}));if(zH>=14)svg.appendChild(tx(cx,zY+zH/2+4,d.z+'%',{fill:C.zdText,size:10,weight:600,anchor:'middle'}));}
    if(d.s>0){const sH=d.s*SCALE;svg.appendChild(mk('rect',{x:bx,y:MT,width:BAR_W,height:sH,fill:C.sage,rx:2}));if(sH>=14)svg.appendChild(tx(cx,MT+sH/2+4,d.s+'%',{fill:'#fff',size:10,weight:700,anchor:'middle'}));}
    svg.appendChild(tx(cx,YB+16,d.m,{fill:C.text,size:10,anchor:'middle'}));
    svg.appendChild(tx(cx,YB+28,d.y,{fill:C.muted,size:9,anchor:'middle'}));
    if(d.retired){
      const px=cx-36,py=YB+52;
      const g=mk('g',{});
      g.appendChild(mk('line',{x1:cx,y1:py-2,x2:cx,y2:YB+38,stroke:C.blue,'stroke-width':1.5}));
      g.appendChild(mk('polygon',{points:`${cx},${YB+33} ${cx-3.5},${YB+38} ${cx+3.5},${YB+38}`,fill:C.blue}));
      g.appendChild(mk('rect',{x:px,y:py,width:72,height:15,rx:7,fill:C.blueBg,stroke:C.blueBdr,'stroke-width':1}));
      g.appendChild(tx(cx,py+10.5,'ZD Bot retired',{fill:C.blue,size:8,weight:500,anchor:'middle'}));
      g.appendChild(mk('animateTransform',{
        attributeName:'transform',type:'translate',
        values:'0,0; 0,-5; 0,0',dur:'1.8s',repeatCount:'indefinite',
        calcMode:'spline',keyTimes:'0; 0.5; 1',keySplines:'0.4 0 0.6 1; 0.4 0 0.6 1'
      }));
      svg.appendChild(g);
    }
  });
})();
</script>

<!-- ── Chart: Topic Breakdown ─────────────────────────────────────────────────── -->
<script is:inline>
(function() {
  const NS='http://www.w3.org/2000/svg';
  const W=720,H=548,ML=200,MR=72,MT=100,MB=32;
  const PW=W-ML-MR,PH=H-MT-MB;
  const BAR_H=40,STEP=52,N=8;
  const TBH=N*BAR_H+(N-1)*12;
  const BY0=MT+(PH-TBH)/2;
  const MX=7,XS=PW/MX;
  function bc(n){const t=(n-2)/(MX-2);return `rgb(${Math.round(4+t*109)},${Math.round(108+t*65)},${Math.round(122+t*8)})`;}
  const cats=[
    {label:'Returns / Pick Lists',  sub1:'Streamline return process,', sub2:'bulk actions',            count:7},
    {label:'Reporting / Visibility',sub1:'Item locations, client',     sub2:'assets, summaries',       count:4},
    {label:'Item Management',       sub1:'Variants, barcode scanning,',sub2:'reordering',              count:4},
    {label:'Inventory Transfers',   sub1:'Location management, user roles',                            count:3},
    {label:'Warehouse Management',  sub1:'Bay creation,',              sub2:'default return locations',count:2},
    {label:'Billing / Invoicing',   sub1:'Invoice correction',                                         count:2},
    {label:'Folder / Structure',    sub1:'Item organization, search',                                  count:2},
    {label:'Undo Functionality',    sub1:'Recovering deleted actions',                                 count:2},
  ];
  const C={text:'#1f2937',muted:'#9ca3af',dim:'#6b7280',teal:'#046c7a',grid:'#f3f4f6',zebra:'#fafafa'};
  const svg=document.getElementById('chart-topics');
  svg.setAttribute('viewBox',`0 0 ${W} ${H}`);
  svg.setAttribute('height',H);
  function mk(t,a,txt){const e=document.createElementNS(NS,t);for(const[k,v]of Object.entries(a))e.setAttribute(k,v);if(txt!==undefined)e.textContent=txt;return e;}
  function tx(x,y,s,{fill=C.text,size=12,weight=400,anchor='start'}={}){return mk('text',{x,y,fill,'font-size':size,'font-weight':weight,'text-anchor':anchor,'font-family':"-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif"},s);}
  svg.appendChild(mk('rect',{width:W,height:H,fill:'#fff'}));
  svg.appendChild(tx(20,30,'What Sage handled in a single week',{size:15,weight:600}));
  svg.appendChild(tx(20,48,'Too complex for ZD bot, Sage resolved without agent handoff',{fill:C.teal,size:11,weight:500}));

  const gt=BY0-4,gb=BY0+TBH+4;
  [1,2,3,4,5,6,7].forEach(v=>svg.appendChild(mk('line',{x1:ML+v*XS,y1:gt,x2:ML+v*XS,y2:gb,stroke:C.grid,'stroke-width':1})));
  svg.appendChild(mk('line',{x1:ML,y1:gt,x2:ML,y2:gb,stroke:'#e5e7eb','stroke-width':1}));
  const pm={7:'27%',4:'15%',3:'12%',2:'8%'};
  const barRects=[],barLabels=[];
  cats.forEach((cat,i)=>{
    const by=BY0+i*52,cy=by+BAR_H/2,bw=cat.count*XS,tl=!!cat.sub2;
    if(i%2===0)svg.appendChild(mk('rect',{x:10,y:by-4,width:W-20,height:BAR_H+8,fill:C.zebra,rx:4}));
    svg.appendChild(tx(20,tl?cy-11:cy-6,cat.label,{fill:C.text,size:11,weight:600}));
    svg.appendChild(tx(20,tl?cy+1:cy+7,cat.sub1,{fill:C.muted,size:9}));
    if(cat.sub2)svg.appendChild(tx(20,cy+12,cat.sub2,{fill:C.muted,size:9}));
    const barEl=mk('rect',{x:ML,y:by,width:0,height:BAR_H,fill:bc(cat.count),rx:4});
    svg.appendChild(barEl);
    barRects.push({el:barEl,target:bw,delay:i*85});
    const labelEl=tx(ML+bw+9,cy+4.5,pm[cat.count]||String(cat.count),{fill:C.dim,size:10,weight:400});
    labelEl.style.opacity='0';
    svg.appendChild(labelEl);
    barLabels.push({el:labelEl,delay:i*85+1100});
  });
  const topicsObs=new IntersectionObserver(entries=>{
    entries.forEach(e=>{
      if(!e.isIntersecting)return;
      topicsObs.disconnect();
      barRects.forEach(({el,target,delay})=>{
        setTimeout(()=>{
          const start=performance.now(),dur=1200;
          (function frame(now){
            const t=Math.min((now-start)/dur,1);
            el.setAttribute('width',target*(1-Math.pow(1-t,3)));
            if(t<1)requestAnimationFrame(frame);
          })(performance.now());
        },delay);
      });
      barLabels.forEach(({el,delay})=>{
        setTimeout(()=>{el.style.transition='opacity 0.25s ease-out';el.style.opacity='1';},delay);
      });
    });
  },{rootMargin:'0px 0px -33% 0px',threshold:0});
  topicsObs.observe(svg);
})();
</script>

<!-- ── Chatbot animation ─────────────────────────────────────────────────────── -->
<script is:inline>
(function() {
  const drawer   = document.getElementById('sage-drawer');
  const msgUser  = document.getElementById('msg-user');
  const typing   = document.getElementById('typing-dots');
  const msgSage  = document.getElementById('msg-sage');
  const helpCard = document.getElementById('help-card');
  if (!drawer) return;

  function set(el, styles) { Object.assign(el.style, styles); }

  function snap(el, hidden) {
    set(el, { transition:'none', opacity: hidden ? '0' : '1',
      transform: el === drawer ? (hidden ? 'translateX(291px)' : 'translateX(0)')
                               : (hidden ? 'translateY(8px)'   : 'translateY(0)') });
  }

  function reveal(el, delay, dur) {
    setTimeout(() => set(el, {
      transition: `opacity ${dur||380}ms ease-out, transform ${dur||380}ms ease-out`,
      opacity:'1', transform: el === drawer ? 'translateX(0)' : 'translateY(0)'
    }), delay);
  }

  function conceal(el, delay, dur) {
    setTimeout(() => set(el, { transition:`opacity ${dur||280}ms ease-in`, opacity:'0' }), delay);
  }

  function resetConversation() {
    [msgUser, typing, msgSage, helpCard].forEach(el => snap(el, true));
  }

  function play() {
    resetConversation();
    setTimeout(() => {
      reveal(msgUser,  50);
      reveal(typing,   900);
      conceal(typing,  2200, 200);
      reveal(msgSage,  2350, 480);
      reveal(helpCard, 3300, 360);
      conceal(msgUser,  5800, 380);
      conceal(msgSage,  6050, 380);
      conceal(helpCard, 6300, 380);
      setTimeout(play, 7400);
    }, 0);
  }

  snap(drawer, true);
  resetConversation();

  setTimeout(() => {
    set(drawer, {
      transition: 'opacity 0.5s ease-out, transform 0.75s cubic-bezier(0.16,1,0.3,1)',
      opacity:'1', transform:'translateX(0)'
    });
    setTimeout(play, 750);
  }, 700);
})();
</script>

<!-- ── Outcomes counter animation ────────────────────────────────────────────── -->
<script is:inline>
(function() {
  const items = Array.from(document.querySelectorAll('.outcome-num[data-target]'));
  items.forEach(el => {
    el.textContent = (el.dataset.prefix || '') + '0' + (el.dataset.suffix || '');
  });
  const band = document.querySelector('.outcomes-band');
  if (!band) return;
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (!e.isIntersecting) return;
      obs.disconnect();
      items.forEach((el, idx) => {
        const prefix = el.dataset.prefix || '';
        const suffix = el.dataset.suffix || '';
        const target = parseInt(el.dataset.target, 10);
        setTimeout(() => {
