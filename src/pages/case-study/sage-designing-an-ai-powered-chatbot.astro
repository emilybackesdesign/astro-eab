---
import PageLayout from '../../layouts/PageLayout.astro';

const pageUrl = 'https://emilybackes.design/case-study/sage-designing-an-ai-powered-chatbot';
const description = "How redesigning Sage from full-page to sidekick doubled resolution rates and cut agent tickets 29%.";
const ogImage = 'https://emilybackes.design/assets/cs/sage/662ad570421ba9e8a98b25bc_og-eb-logo.png';
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Article",
      "headline": "Designing Sage — An AI Powered Chatbot",
      "description": description,
      "image": ogImage,
      "author": {
        "@type": "Person",
        "@id": "https://emilybackes.design/#person",
        "name": "Emily Backes",
        "url": "https://emilybackes.design/"
      },
      "keywords": ["AI", "Chatbot", "UX Design", "Conversational Design", "Product Design", "SaaS"],
      "about": ["AI", "Chatbot", "UX Design"],
      "mainEntityOfPage": pageUrl,
      "datePublished": "2024"
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://emilybackes.design/" },
        { "@type": "ListItem", "position": 2, "name": "Case Studies", "item": "https://emilybackes.design/#case-study-section" },
        { "@type": "ListItem", "position": 3, "name": "Designing Sage — An AI Powered Chatbot", "item": pageUrl }
      ]
    }
  ]
};
---
<PageLayout title="Designing Sage — An AI Powered Chatbot | Emily Backes" description={description} ogImage="/assets/cs/sage/662ad570421ba9e8a98b25bc_og-eb-logo.png" bodyBg="#f3f7f4">
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
<div class="sage-main-wrapper"><div id="sage-header-hero-section" class="sage-header-hero-section"><div id="sage-page-header" class="sage-page-header"><div class="inline-div-0"><span class="inline-span-0"></span><span class="inline-span-1"></span><span>AI / Chatbot</span><span class="inline-span-2"></span><span>2024–2026</span></div><h1 class="inline-h1-0">How I Doubled Chatbot Resolution Rate and Cut Agent Tickets 29% by Turning Sortly Sage from a Full Page into a Sidekick</h1><p class="inline-p-0">When we shipped the full-page beta at 10% of users, it outperformed the old bot immediately. Users were also opening second browser windows to follow its instructions. That one behavior told me everything: accurate answers don&#x27;t matter if the container fights the user.</p></div><div id="sage-hero-placeholder" class="sage-hero-visual"><div class="w-embed"><!-- ── Animated Chatbot Hero ─────────────────────────────────────────────────── -->
