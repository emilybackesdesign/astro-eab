<script is:inline>
(function () {
  var svg = document.getElementById('hero-svg');
  if (!svg) return;

  var LENS = { 'hl-0':82,'hl-1':82,'hl-2':82,'hl-3':82,'hl-b':48,'hl-ch':540 };
  Object.keys(LENS).forEach(function (id) {
    var el = document.getElementById(id);
    if (el) { el.style.strokeDasharray = LENS[id]; el.style.strokeDashoffset = LENS[id]; }
  });
  svg.querySelectorAll('.hl-cd').forEach(function (el) { el.style.strokeDasharray = 10;  el.style.strokeDashoffset = 10; });
  svg.querySelectorAll('.hl-cc').forEach(function (el) { el.style.strokeDasharray = 50;  el.style.strokeDashoffset = 50; });

  function draw(id, dur, t) {
    setTimeout(function () {
      var el = document.getElementById(id);
      if (el) { el.style.transition = 'stroke-dashoffset ' + dur + 'ms cubic-bezier(0.4,0,0.2,1)'; el.style.strokeDashoffset = 0; }
    }, t);
  }
  function drawAll(sel, dur, t0, gap) {
    svg.querySelectorAll(sel).forEach(function (el, i) {
      setTimeout(function () {
        el.style.transition = 'stroke-dashoffset ' + dur + 'ms cubic-bezier(0.4,0,0.2,1)'; el.style.strokeDashoffset = 0;
      }, t0 + i * gap);
    });
  }
  function fade(id, dur, t) {
    setTimeout(function () {
      var el = document.getElementById(id);
      if (el) { el.style.transition = 'opacity ' + dur + 'ms ease'; el.style.opacity = 1; }
    }, t);
  }

  function run() {
    var t = 0;
    /* Existing deletion flow — left to right */
    fade('hn-d1', 380, t);  t += 220;
    draw('hl-0',  260, t);  t += 320;
    fade('hn-d2', 380, t);  t += 220;
    draw('hl-1',  260, t);  t += 320;
    fade('hn-d3', 440, t);  t += 340;
    draw('hl-2',  260, t);
    setTimeout(function() { fade('hn-d4', 380, t + 300); }, 0);
    setTimeout(function() { draw('hl-3',  260, t + 300); }, 0);
    setTimeout(function() { fade('hn-d5', 380, t + 620); }, 0);
    t += 1050;

    /* New cancel flow emerges from D3 */
    draw('hl-b',  380, t);              t += 450;
    draw('hl-ch', 520, t);              t += 580;
    drawAll('.hl-cd', 130, t, 90);
    setTimeout(function() {
      fade('hn-c1', 340, t + 70);
      fade('hn-c2', 340, t + 190);
      fade('hn-c3', 340, t + 310);
      fade('hn-c4', 340, t + 430);
    }, 0);
    t += 640;
    drawAll('.hl-cc', 220, t, 100);
  }

  new IntersectionObserver(function (entries, obs) {
    if (entries[0].isIntersecting) { obs.disconnect(); run(); }
  }, { threshold: 0.05 }).observe(svg);
}());
</script></div></div><div id="company-cancel-problem-section" class="company-cancel-process-section band band--dark"><div class="band-col inline-div-20"><div class="eyebrow inline-div-19"><strong>The Problem</strong></div><h2 class="inline-h2-1">Our user had exactly two cancellation options: call customer support, or delete their account entirely</h2><p class="inline-p-6-1">The deletion route worked. Technically. But over 40 customers a month were coming back after deleting, forced to start from scratch. Their data, their setup, their history: gone. <br/><br/>The reactivation rate was sitting at 4.5%.Every returning customer was paying a tax they shouldn&#x27;t have had to.</p></div><div class="asset-wrap inline-div-21"><div class="w-embed"><style>

