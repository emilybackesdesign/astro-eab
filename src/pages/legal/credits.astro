---
import PageLayout from '../../layouts/PageLayout.astro';
---
<PageLayout title="Credits — Emily Backes">
  <div class="legal-page">
    <h1 class="legal-heading">Credits</h1>
    <div class="legal-body">
      <p class="credits-intro">I design&hellip; with a little help from my friends.</p>

      <ul class="credits-list">
        <li>
          Music by <a href="https://youtu.be/alWfFV-j0Tw" target="_blank" rel="noopener noreferrer">Alex-Productions</a>
        </li>
        <li>
          <a href="https://lordicon.com" target="_blank" rel="noopener noreferrer">Animated Icons by: Lordicon</a>
        </li>
        <li>
          <a href="https://lottiefiles.com/search?q=cat+loader&category=animations" target="_blank" rel="noopener noreferrer">Animated Icons by: LottieFiles</a>
        </li>
        <li>
          AI images generated by Midjourney
        </li>
      </ul>
    </div>
  </div>
</PageLayout>

<style>
  .legal-page {
    max-width: 780px;
    margin: 0 auto;
    padding: var(--lg-spacer) 1.5rem;
  }
  .legal-heading {
    font-family: 'Pridi', serif;
    font-size: var(--h1);
    color: var(--ink);
    letter-spacing: -0.5px;
    margin-bottom: var(--md-spacer);
  }
  .legal-body {
    color: var(--body);
    font-family: 'Public Sans', sans-serif;
    font-size: var(--text-body);
    line-height: 1.7;
  }
  .legal-body :global(h2) {
    font-family: 'Pridi', serif;
    color: var(--ink);
    font-size: var(--h3);
    margin-top: var(--lg-spacer);
  }
  .legal-body :global(h3) {
    font-family: 'Pridi', serif;
    color: var(--ink);
    font-size: var(--h4);
  }
  .legal-body :global(a) {
    color: var(--toe-bean-pink-200);
  }
  .credits-intro {
    font-family: 'Pridi', serif;
    font-size: var(--h3);
    color: var(--ink);
    margin-bottom: var(--md-spacer);
  }
  .credits-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .credits-list li {
    font-size: var(--text-body);
  }
  .credits-list a {
    color: var(--toe-bean-pink-200);
    text-decoration: none;
  }
  .credits-list a:hover {
    text-decoration: underline;
  }
</style>
