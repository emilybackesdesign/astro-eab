---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout
  title="Resume — Emily Backes"
  description="Resume of Emily Backes, Product Designer — 10 years of experience in UX/UI, product design, and research."
>

  <!-- ── Hero ─────────────────────────────────────────────────────────────── -->
  <section class="resume-hero" data-aos="fade-up">
    <div class="page-wrap">
      <span class="label-caps eyebrow">Product Designer</span>
      <h1 class="resume-name">Emily Backes</h1>
      <p class="resume-summary">
        10 years of professional experience in project management, technical
        recruiting, design, and a BA in Sociology from the University of Colorado.
        Interested in Product Design, UX/UI Research, or Freelance product design
        positions.
      </p>
      <div class="contact-row">
        <span class="contact-item">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          Denver, CO
        </span>
        <span class="contact-sep">·</span>
        <a href="tel:3039956685" class="contact-item contact-link">303.995.6685</a>
        <span class="contact-sep">·</span>
        <a href="mailto:emilybackes.design@gmail.com?subject=Emily%20Backes%20Draft" class="contact-item contact-link">
          emilybackes.design@gmail.com
        </a>
        <span class="contact-sep">·</span>
        <a href="https://www.linkedin.com/in/emilybackes/" target="_blank" rel="noopener" class="contact-item contact-link">
          in/emilybackes
        </a>
      </div>
    </div>
  </section>

  <!-- ── PDF Viewer ────────────────────────────────────────────────────────── -->
  <section class="pdf-section" data-aos="fade-up">
    <div class="page-wrap">

      <div class="pdf-actions">
        <!--
          NOTE: /resume.pdf does not exist yet — add the file to the /public
          directory. The page wiring is complete; it will work once the PDF is placed.
        -->
        <a href="/resume.pdf" download="Emily-Backes-Resume.pdf" class="btn-download">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="7 10 12 15 17 10"/>
            <line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
          Download PDF
        </a>
        <a href="/resume.pdf" target="_blank" rel="noopener" class="btn-ghost">
          Open in new tab
        </a>
      </div>

      <div class="pdf-frame-wrap">
        <iframe
          src="/resume.pdf"
          title="Emily Backes Resume"
          class="resume-iframe"
          loading="lazy"
          id="resume-iframe"
        ></iframe>
        <p class="pdf-fallback" id="pdf-missing-msg" style="display:none">
          Resume PDF loading&hellip; If it doesn&rsquo;t appear,
          <a href="/resume.pdf" class="pink-link">download it directly</a>.
        </p>
        <noscript>
          <p class="pdf-fallback">
            Your browser cannot display the PDF inline.
            <a href="/resume.pdf" class="pink-link">Download it here.</a>
          </p>
        </noscript>
      </div>
      <script>
        (function () {
          var iframe = document.getElementById('resume-iframe');
          var msg = document.getElementById('pdf-missing-msg');
          if (!iframe || !msg) return;
          // Show the fallback message immediately — it stays visible until the
          // iframe reports a successful load (i.e. the PDF exists).
          msg.style.display = 'block';
          iframe.addEventListener('load', function () {
            // A real PDF load hides the message; a 404 keeps it showing.
            try {
              // Accessing contentDocument throws on cross-origin or successful
              // PDF plugin loads — either way means something loaded.
              msg.style.display = 'none';
            } catch (_) {
              msg.style.display = 'none';
            }
          });
          iframe.addEventListener('error', function () {
            msg.style.display = 'block';
          });
        })();
      </script>

    </div>
  </section>

  <!-- ── Highlights snapshot ──────────────────────────────────────────────── -->
  <section class="highlights-section" data-aos="fade-up">
    <div class="page-wrap highlights-grid">

      <div class="highlight-col">
        <h2 class="col-heading label-caps">Experience</h2>
        <ul class="exp-list">
          <li class="exp-item">
            <span class="exp-role">Product Designer</span>
            <span class="exp-company">Sortly</span>
            <span class="exp-year">2024</span>
          </li>
          <li class="exp-item">
            <span class="exp-role">Product Designer</span>
            <span class="exp-company">Bowtie</span>
            <span class="exp-year">2024</span>
          </li>
          <li class="exp-item">
            <span class="exp-role">UX Strategy Lead</span>
            <span class="exp-company">Tech Fleet</span>
            <span class="exp-year">2022–2023</span>
          </li>
          <li class="exp-item">
            <span class="exp-role">Product Designer</span>
            <span class="exp-company">Ronin & Co</span>
            <span class="exp-year">2021–2023</span>
          </li>
          <li class="exp-item">
            <span class="exp-role">UX Design (Student)</span>
            <span class="exp-company">General Assembly</span>
            <span class="exp-year">2022</span>
          </li>
        </ul>
      </div>

      <div class="highlight-col">
        <h2 class="col-heading label-caps">Skills</h2>
        <div class="chips-row">
          <span class="chip">User Testing</span>
          <span class="chip">Wireframes</span>
          <span class="chip">Hi-Fidelity</span>
          <span class="chip">UX Research</span>
          <span class="chip">UI Design</span>
          <span class="chip">Figma</span>
          <span class="chip">Agile</span>
          <span class="chip">Leadership</span>
          <span class="chip">Mentorship</span>
          <span class="chip">Project Management</span>
        </div>
        <h2 class="col-heading label-caps" style="margin-top:var(--md-spacer)">Tools</h2>
        <div class="chips-row">
          <span class="chip">Miro</span>
          <span class="chip">Maze</span>
          <span class="chip">Webflow</span>
          <span class="chip">Notion</span>
          <span class="chip">Zeplin</span>
          <span class="chip">Sketch</span>
          <span class="chip">ChatGPT</span>
        </div>
        <h2 class="col-heading label-caps" style="margin-top:var(--md-spacer)">Certifications</h2>
        <div class="chips-row">
          <span class="chip">Webflow 101</span>
          <span class="chip">General Assembly UX Design</span>
        </div>
      </div>

    </div>
  </section>

  <!-- ── CTA ───────────────────────────────────────────────────────────────── -->
  <section class="cta-row" data-aos="fade-up">
    <div class="page-wrap cta-inner">
      <a href="/contact" class="btn-primary">Let's Chat</a>
      <a href="/about" class="btn-ghost">About Me</a>
      <a href="/the-5-pillars-of-emily" class="btn-ghost">5 Pillars of Emily</a>
    </div>
  </section>

</PageLayout>

<style>
  /* ── Layout ──────────────────────────────────────────────────────────── */
  .page-wrap {
    max-width: 1030px;
    margin: 0 auto;
    padding: 0 var(--sp-6);
  }

  section {
    padding: var(--lg-spacer) 0;
  }

  /* ── Hero ────────────────────────────────────────────────────────────── */
  .resume-hero {
    padding-top: var(--xl-spacer);
    background-color: var(--bg);
  }

  .eyebrow {
    display: block;
    color: var(--muted);
    margin-bottom: var(--xs-spacer);
    letter-spacing: 3px;
  }

  .resume-name {
    font-size: clamp(var(--h3), 5vw, var(--h1));
    color: var(--ink);
    margin-bottom: var(--def-spacer);
  }

  .resume-summary {
    font-size: 1.05rem;
    color: var(--body);
    max-width: 680px;
    line-height: 1.65;
    margin-bottom: var(--md-spacer);
  }

  .contact-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--xs-spacer) var(--sm-spacer);
    align-items: center;
    font-size: var(--text-sm);
    color: var(--muted);
  }

  .contact-sep {
    color: var(--subtle);
  }

  .contact-item {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    color: var(--muted);
  }

  .contact-link {
    color: var(--toe-bean-pink-200);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.15s;
  }

  .contact-link:hover {
    color: var(--toe-bean-pink-300, #c88f96);
  }

  /* ── PDF section ─────────────────────────────────────────────────────── */
  .pdf-section {
    background-color: var(--surface);
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }

  .pdf-actions {
    display: flex;
    gap: var(--def-spacer);
    align-items: center;
    margin-bottom: var(--md-spacer);
    flex-wrap: wrap;
  }

  .btn-download {
    display: inline-flex;
    align-items: center;
    gap: var(--xs-spacer);
    font-family: 'Public Sans', sans-serif;
    font-size: var(--text-extra-sm);
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    background-color: var(--toe-bean-pink-200);
    color: #333;
    border-radius: 4px;
    padding: 10px 20px;
    transition: background-color 0.15s;
    text-decoration: none;
  }

  .btn-download:hover {
    background-color: var(--toe-bean-pink-300, #c88f96);
  }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    font-family: 'Public Sans', sans-serif;
    font-size: var(--text-extra-sm);
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    background-color: transparent;
    color: var(--toe-bean-pink-200);
    border: 1px solid var(--toe-bean-pink-200);
    border-radius: 4px;
    padding: 10px 20px;
    transition: background-color 0.15s;
    text-decoration: none;
  }

  .btn-ghost:hover {
    background-color: color-mix(in srgb, var(--toe-bean-pink-200) 10%, transparent);
  }

  .pdf-frame-wrap {
    width: 100%;
    background-color: var(--elevated);
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid var(--rule-strong);
  }

  .resume-iframe {
    display: block;
    width: 100%;
    height: 80vh;
    min-height: 600px;
    border: none;
  }

  .pdf-fallback {
    padding: var(--lg-spacer);
    text-align: center;
    color: var(--muted);
  }

  .pink-link {
    color: var(--toe-bean-pink-200);
    text-decoration: underline;
  }

  /* ── Highlights ──────────────────────────────────────────────────────── */
  .highlights-section {
    background-color: var(--bg);
  }

  .highlights-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--lg-spacer);
  }

  @media (max-width: 640px) {
    .highlights-grid {
      grid-template-columns: 1fr;
    }
  }

  .col-heading {
    color: var(--toe-bean-pink-200);
    letter-spacing: 3px;
    margin-bottom: var(--sm-spacer);
    font-family: 'Public Sans', sans-serif;
    font-size: var(--text-extra-sm);
  }

  .exp-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--sm-spacer);
  }

  .exp-item {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-rows: auto auto;
    gap: 2px var(--xs-spacer);
    padding-bottom: var(--xs-spacer);
    border-bottom: 1px solid var(--rule);
  }

  .exp-role {
    font-size: var(--text-sm);
    color: var(--ink);
    font-weight: 600;
    grid-column: 1;
    grid-row: 1;
  }

  .exp-company {
    font-size: var(--text-extra-sm);
    color: var(--muted);
    letter-spacing: 1px;
    text-transform: uppercase;
    grid-column: 1;
    grid-row: 2;
  }

  .exp-year {
    font-size: var(--text-extra-sm);
    color: var(--subtle);
    grid-column: 2;
    grid-row: 1 / 3;
    align-self: center;
  }

  .chips-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--xs-spacer);
  }

  .chip {
    display: inline-block;
    font-family: 'Public Sans', sans-serif;
    font-size: var(--text-extra-sm);
    font-weight: 400;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--toe-bean-pink-200);
    border: 1px solid var(--toe-bean-pink-200);
    border-radius: 4px;
    padding: 4px 10px;
  }

  /* ── CTA ─────────────────────────────────────────────────────────────── */
  .cta-row {
    background-color: var(--surface);
    border-top: 1px solid var(--rule);
  }

  .cta-inner {
    display: flex;
    flex-wrap: wrap;
    gap: var(--def-spacer);
    align-items: center;
    justify-content: center;
  }

  .btn-primary {
    display: inline-block;
    font-family: 'Public Sans', sans-serif;
    font-size: var(--text-extra-sm);
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    background-color: var(--toe-bean-pink-200);
    color: #333;
    border-radius: 4px;
    padding: 10px 20px;
    transition: background-color 0.15s;
    text-decoration: none;
  }

  .btn-primary:hover {
    background-color: var(--toe-bean-pink-400, #c88f96);
  }
</style>
