---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout
  title="The 5 Pillars of Emily — Emily Backes"
  description="Five Pillars — Emily Backes' search for meaningful impact: ethics, collaboration, transparency, balance, and happiness."
  extraFonts={['Lexend', 'Inconsolata']}
>

  <div class="pillars-page">

    <!-- ── Hero ───────────────────────────────────────────────────────────── -->
    <section class="_5p_hero__section">
      <div class="w-layout-blockcontainer _5p_hero__container w-container">
        <div class="_5p_hero__wrapper">
          <div class="hero_heading__wrapper">
            <h1 class="heading-62" data-aos="fade-up">Five Pillars, <br/>My Search for <br/>Meaningful Impact.<br/></h1>
            <div class="div-block-146">
              <div class="text-block-107">Nurturing personal and professional growth <br/>with purpose in the next phase of my career.</div>
            </div>
          </div>
          <div class="hero_card__wrapper">
            <div class="pillar_card__wrapper _5p_ethics_card">
              <img src="/assets/images/pillar_one.avif" loading="lazy" alt="Ethics and Sustainability" class="_5p_pillar_one" data-aos="fade-up" data-aos-delay="0"/>
            </div>
            <div class="pillar_card__wrapper _5p_collab__card">
              <img src="/assets/images/pillar_2.svg" loading="lazy" alt="Collaboration" class="_5p_pillar_two" data-aos="fade-up" data-aos-delay="100"/>
            </div>
            <div class="pillar_card__wrapper _5p_trans__card">
              <img src="/assets/images/pillar_3.svg" loading="lazy" alt="Transparency" class="_5p_pillar_three" data-aos="fade-up" data-aos-delay="200"/>
            </div>
            <div class="pillar_card__wrapper _5p_balance__card">
              <img src="/assets/images/pillar_4.svg" loading="lazy" alt="Balance" class="_5p_pillar_four" data-aos="fade-up" data-aos-delay="300"/>
            </div>
            <div class="pillar_card__wrapper _5p_happiness__card">
              <img src="/assets/images/pillar_5.svg" loading="lazy" alt="Happiness" class="_5p_pillar_five" data-aos="fade-up" data-aos-delay="400"/>
            </div>
          </div>
          <div class="_5p_hero__post__stats">
            <div class="read_time__wrapper">
              <img src="/assets/images/reading_time.svg" loading="lazy" alt="" class="image-86"/>
              <div class="text-block-108">5 minute read</div>
            </div>
            <div class="read_time__wrapper">
              <img src="/assets/images/headphones.svg" loading="lazy" alt="" class="image-86"/>
              <div class="text-block-108">10 minute listen</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Intro + inline podcast ─────────────────────────────────────────── -->
    <section class="_5p_intro__section">
      <div class="_5p_intro__container">
        <div class="_5p_intro__wrapper">
          <div class="_5p_intro__content" data-aos="fade-up">
            <div class="intro_heading">
              <img src="/assets/images/introduction.svg" loading="lazy" alt="" class="image-74" />
              <h2 class="heading-56">What is all this about?</h2>
            </div>
            <div class="intro_text__content">
              <div class="text-block-98">
                My 10+ year professional career has given me experience in a variety of settings. I&rsquo;ve worked for companies that range from start-ups all the way to one of the top staffing firms in America. <br /><br />
                I&rsquo;ve worked fully on-site, hybrid, and fully remote (last 5 years) and can see the value in both settings. <br /><br />
                I&rsquo;ve worked in cubicle farms, private offices, a windowless building, and a home office.
              </div>
              <div class="text-block-98">
                I&rsquo;ve worked as an individual contributor and as a member of a team and as a combination of the two.<br /><br />
                Suffice it to say, that I&rsquo;ve been able to figure out what environments are mutually beneficial for myself and the company that employs me. <br /><br />
                I was recently challenged to document five pillars that culminate my ideals when looking for the next stage of my career.
              </div>
            </div>
          </div>
          <div class="blogcast_wrapper" data-aos="fade-up">
            <div class="blogcast_content_wrapper">
              <div class="blogcast_heading">
                <img src="/assets/images/easy_listening.svg" loading="lazy" alt="" class="p5_easy__listening" />
                <h2 class="heading-63">Listen instead</h2>
              </div>
              <div class="blogcast_embed">
                <div class="code-embed">
                  <iframe
                    title="Five Pillars, My Search for Meaningful Impact."
                    src="https://www.podbean.com/player-v2/?i=vi7p2-160aa77-pb&from=pb6admin&square=1&share=1&download=1&rtl=0&fonts=Arial&skin=1b1b1b&font-color=auto&logo_link=episode_page&btn-skin=fb0584&size=280"
                    height="280"
                    width="100%"
                    data-name="pb-iframe-player"
                    allowtransparency="true"
                    loading="lazy"
                    style="border: 0; width: 100%; min-width: min(100%, 430px); height: 280px; border-radius: 8px; overflow: hidden;"
                  ></iframe>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Pillar 1: Ethics & Sustainability ──────────────────────────────── -->
    <section class="_5p_ethics__section">
      <div class="w-layout-blockcontainer _5p_ethics__container w-container">
        <div class="_5p_ethics__wrapper">
          <div class="_5p_ethics__text">
            <div class="ethics_heading">
              <img src="/assets/images/ethics_and_sustainability.svg" loading="lazy" alt="" class="_5p_ethics" />
              <h2 class="heading-57">From Plastic-Free Kitchen to Meeting-Free Mayhem</h2>
            </div>
            <div class="ethics_text__content">
              <div class="text-block-99">
                About three years ago, I embarked on a journey to make my life more plastic-free. Although this effort is constantly evolving and will never be perfect, sustainability is something that occupies at least some of my thoughts every day. <br /><br />
                The ultimate goal is to only own things I will use and reduce waste. I also strive to incorporate this practice professionally. I consider eliminating redundancies to be sustainable and ethical.
              </div>
              <div>
                <div class="text-block-112">Although this effort is constantly evolving and will never be perfect, sustainability is something that occupies at least some of my thoughts every day. </div>
              </div>
              <div class="text-block-99">
                After working in an agile environment, I&rsquo;ve discovered that it has the highest potential for sustainability. Having a clear road map and sprint cycles means you are constantly prioritizing the most important thing. <br /><br />
                I&rsquo;m used to being in an environment where you are consistently chasing a moving target, sometimes finding that the target has disappeared into thin air. With product design and management, there are clear goals and having regular communication is the best way to eliminate confusion and ultimately discover redundancies.
              </div>
            </div>
          </div>
          <div class="_5p_ethics__images">
            <img src="/assets/images/group_chat_v3.svg" loading="lazy" alt="" class="_5p_ethics__base__image" />
            <img src="/assets/images/chat_bubble_3.svg" loading="lazy" alt="" class="bubble_1" data-aos="zoom-in" data-aos-delay="150" />
            <img src="/assets/images/chat_bubble_2.svg" loading="lazy" alt="" class="bubble_2" data-aos="zoom-in" data-aos-delay="300" />
            <img src="/assets/images/chat_bubble_1.svg" loading="lazy" alt="" class="bubble_3" data-aos="zoom-in" data-aos-delay="450" />
          </div>
        </div>
      </div>
    </section>

    <!-- ── Pillar 2: Collaboration ─────────────────────────────────────────── -->
    <section class="_5p_collab__section">
      <div class="w-layout-blockcontainer _5p_collab__container w-container">
        <div class="_5p_collab__wrapper">
          <div class="_5p_collab__content__wrapper">
            <div class="collab_left__wrapper">
              <img src="/assets/images/collab_character_left_pencil.svg" loading="lazy" alt="Character with pencil" class="image-93" />
            </div>

            <div class="collab_content">
              <div class="collab_heading">
                <img src="/assets/images/collaboration.svg" loading="lazy" alt="" class="_5p_collab" />
                <h2 class="heading-58">
                  <strong class="bold-text-19">Leading by Example &amp; Working with<br />a Collaborative Team</strong>
                </h2>
              </div>

              <div class="collab_text__content">
                <div class="collab_txt__left">
                  <div class="div-block-144">
                    <img src="/assets/images/collab_left_v2.svg" loading="lazy" width="125" alt="" data-aos="fade-right" />
                  </div>
                  <div class="text-block-103">
                    Early in my career, I had the privilege of working under an exceptional Program Manager who had a distinguished military background. <br /><br />
                    He taught me how to identify the qualities of a great leader and effectively lead a team located hundreds of thousands of miles away. <br /><br />
                    Concurrently, I was part of an operations team comprising other professionals who held similar roles for different contracts.
                  </div>
                  <div class="text-block-103">
                    This dynamic environment allowed for collaboration while also providing opportunities for individual contributions. <br /><br />
                    I learned from my peers, iterated on my team&rsquo;s user experience, streamlined processes, and shared my successes and failures with the operations team. <br /><br />
                    The individuals we supported consistently praised us for delivering the best user experience they had encountered in any contract.
                  </div>
                </div>

                <div class="collab_txt__right">
                  <div class="collab_twisted__right">
                    <img src="/assets/images/collab_right_v2.svg" loading="lazy" width="125" alt="" data-aos="fade-left" />
                  </div>
                  <div class="collab_twisted__left">
                    I experienced many different dynamics as a recruiter, working as a team, working in direct competition with my peers, working as an individual contributor and mentoring Jr recruiters. Recruiting certainly taught me how to constantly re-prioritize. I also learned that I am not motivated by competition with my peers.
                  </div>
                  <div class="text-block-112">
                    I would rather focus on leading a group or contributing to solving a common goal.
                  </div>
                  <div class="collab_twisted__left">
                    I faced some unfortunate and challenging circumstances that taught me essential lessons about advocating for myself, however I would rather focus on leading a group or contributing to solving a common goal. <br /><br />
                    I have also been told that teaching is one of my strongest attributes. The value that led me to UX is that even though you may have different teams with conflicting priorities and interests, at the end of the day you are all working toward a common goal.
                  </div>
                </div>
              </div>
            </div>

            <div class="collab_right__wrapper">
              <img src="/assets/images/collab_character_right_brush.svg" loading="lazy" alt="Character with paint brush" class="image-92" />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Pillar 3: Transparency ──────────────────────────────────────────── -->
    <section class="_5p_transparency__section">
      <div class="_5p_transparency__wrapper">
        <div class="div-block-150" data-aos="fade-right">
          <img src="/assets/images/transparency_v2.svg" loading="lazy" alt="Character with magnifying glass" class="image-98" />
        </div>
        <div class="div-block-149">
          <div class="transparency_heading" data-aos="fade-up">
            <img src="/assets/images/transparency.svg" loading="lazy" alt="" class="_5p_trans" />
            <h2 class="trans_main__heading">A Call for Transparency in the Human Exchange</h2>
          </div>
          <div class="transparency_text__context" data-aos="fade-up">
            <div class="text-block-104">
              My current employer found me on LinkedIn by typing in a few key words he was looking for. He messaged me and I honestly didn&rsquo;t know I was interviewing when I first spoke to him. As a long standing independent business owner he was incredibly transparent with me from the jump.<br /><br />
              He told me what his need was, he gave me an accurate and conservative estimate of how long the contract work he had on deck would take and didn&rsquo;t make any promises he couldn&rsquo;t keep. <br /><br />
              This foundational transparency is ingrained in the company ethos. We will celebrate when it&rsquo;s time to celebrate, we will do great work and make great products but don&rsquo;t expect a ton of hand holding. <br /><br />
              The culture in my current company is in contrast with a lot of corporate speak and mention of perks (not to be confused with benefits) that is baked into every corporation&rsquo;s job description. <br /><br />
              I have also worked for companies who talk the talk and say they walk the walk but that walk is no more than a thinly veiled attempt to meet a mandated metric or criteria.<br />
            </div>
            <div class="text-block-104">
              I have learned over the years that I have no interest in shallow corporate requirements and meaningless metrics. <br /><br />
              My last straw in recruiting was when I had spent 3 months hiring someone, she left a full-time role for a contract role and 6 weeks after starting, they laid her off and her manager took a job elsewhere. <br /><br />
              I&rsquo;m not afraid to say that this practice happens often and it is egregious. That&rsquo;s not to say there aren&rsquo;t great teams and managers within these large corporate environments but the innate qualities of a corporation do not make transparency easy for their employees. <br /><br />
              I never want to put someone else or myself in that situation again at the hands of a corporation&rsquo;s inability to plan for the future and be transparent with their employees. <br /><br />
              Interviewing and job hunting are some of the most stressful interruptions someone can go through in their adulthood. Recruiters that aren&rsquo;t transparent with their candidates shouldn&rsquo;t be in staffing.
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Pillar 4: Balance ───────────────────────────────────────────────── -->
    <section class="_5p_balance__section">
      <div class="w-layout-blockcontainer _5p_balance__container w-container">
        <div class="_5p_balance__wrapper">
          <div class="_5p_balance__content__wrapper">
            <div class="balance_heading">
              <img src="/assets/images/balance.svg" loading="lazy" alt="" class="_5p_balance" />
              <h2 class="heading-60"><strong class="bold-text-20">Beyond the Call of Duty: When Work Nearly Took my Vision</strong></h2>
            </div>
            <div class="balance_text__content">
              <div class="text-block-105">To put it simply, I used to be responsible for remotely executing action plans when people&rsquo;s lives and livelihoods were at stake. I was a workaholic, constantly connected to my Blackberry (I&rsquo;m dating myself here). <br /><br />I found myself answering non-emergency emails late at night to accommodate my employees in different time zones, literally across the world in a war zone. During a performance review, my boss advised me to put away my Blackberry after work and assured me that if a real emergency occurred, he would contact me on my personal line.</div>
              <div class="text-block-112">In the summer of 2023, I briefly lost about 70% of my eyesight during a period of high stress. No amount of time in front of a screen is worth my eyesight and I won&rsquo;t make that mistake again.</div>
              <div class="text-block-105">As I have progressed in my professional life, I have come to realize that I cannot be effective without maintaining a healthy work-life balance. Let me be clear, achieving this balance is something I actively strive for every day. As a perfectionist, I have let my inability to prioritize myself take a physical toll. <br /><br />In the summer of 2023, I briefly lost about 70% of my eyesight during a period of high stress. No amount of time in front of a screen is worth my eyesight and I won&rsquo;t make that mistake again. If I have PTO to use, I'm going to use it and spend that time focused on my loved ones. Which brings me to my next and final pillar&hellip;</div>
            </div>
          </div>
          <div class="_5p_balance__img__wrapper">
            <div class="balance_images">
              <img src="/assets/images/balance_character.svg" loading="lazy" alt="Character Yoga Balance" class="balance_character" />
              <img src="/assets/images/balance_cat.svg" loading="lazy" alt="" class="balance_cat" data-aos="zoom-in" data-aos-delay="200" />
              <img src="/assets/images/balance_lines.svg" loading="lazy" alt="" class="balance_lines" data-aos="fade-up" data-aos-delay="400" />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Pillar 5: Happiness ─────────────────────────────────────────────── -->
    <section class="_5p_happiness__section">
      <div class="_5p_happiness__container">
        <div class="_5p_happy__group" data-aos="fade-right">
          <img src="/assets/images/happiness_group.svg" loading="lazy" alt="Happy Group" class="image-99" />
        </div>
        <div class="_5p_happiness__wrapper">
          <div class="div-block-143" data-aos="fade-up">
            <img src="/assets/images/happiness.svg" loading="lazy" alt="" class="_5p_happy" />
            <h2 class="heading-61">Meme Master &amp; Work BFF: How I Make the Office a Joyful Place</h2>
          </div>
          <p class="text-block-106" data-aos="fade-up">
            There's a lyric from Brandi Carlile's song where she asks, "Do I make myself a blessing to everyone I meet?" I try to ask myself that question regularly. Being an extrovert, I recharge by being around people, and I believe that taking a few minutes each day to laugh and bring joy to others is essential. In every job I've had, I have formed at least one work BFF.
          </p>
          <p class="text-block-112" data-aos="fade-up">A previous boss was a therapist in another life and I like to think that 90% of management is being a good therapist.</p>
          <p class="text-block-106" data-aos="fade-up">
            Some of these colleagues have become lifelong friends because we provided support and happiness to each other during difficult times.
          </p>
        </div>
      </div>
    </section>

    <!-- ── So, What's Next? ────────────────────────────────────────────────── -->
    <section class="_5p_next__section">
      <div class="_5p_next__container">
        <div class="_5p_next__wrapper">
          <div class="_5p_whats__next" data-aos="fade-up">
            <div class="_5p_next_l_graphic__wrapper">
              <img src="/assets/images/semi_circle_left.svg" loading="lazy" width="150" alt="" data-aos="fade-left" class="_5p_right_half__circle" />
            </div>
            <div class="_5p_next__content">
              <img src="/assets/images/now_what.svg" loading="lazy" alt="" class="_5p_now__what" />
              <h2 class="heading-64">So, What's Next?</h2>
              <div class="_5p_next__text">
                <p class="text-block-109">
                  As someone from the "you get what you get and you don't have a fit"
                  generation, I understand that individuals that are new-to-career may
                  not have the experience and quite frankly, luxury, to be so
                  particular.
                </p>
                <p class="text-block-109">
                  As a career professional, I bring ten years of experience with
                  conflict resolution, negotiation, meaningful compromise,
                  professionalism, and a high EQ to assess priorities.
                </p>
                <p class="text-block-109">
                  I'm seeking <strong>ethics and sustainability</strong>,
                  <strong>collaboration</strong>, <strong>transparency</strong>,
                  <strong>balance</strong>, and <strong>happiness</strong> as
                  foundational qualities in future work and colleagues.
                </p>
              </div>
            </div>
          </div>

          <div class="_5p_contact__me" data-aos="fade-up">
            <div class="_5p_next_r_graphic__wrapper">
              <img src="/assets/images/semi_circle_right.svg" loading="lazy" width="150" alt="" data-aos="fade-right" class="_5p_left_half__circle" />
            </div>
            <div class="_5p_contact__information">
              <div class="div-block-156">
                <div class="text-block-110">Want to collaborate?</div>
                <div class="div-block-159">
                  <img src="/assets/images/arrow_right_icon.svg" loading="lazy" alt="" class="image-96" />
                  <h5 class="heading-65"><a href="/contact" class="link-9">Contact me</a></h5>
                </div>
              </div>
              <div class="div-block-156">
                <div class="text-block-110">Looking for my resume?</div>
                <div class="div-block-159">
                  <img src="/assets/images/arrow_right_icon.svg" loading="lazy" alt="" class="image-96" />
                  <h5 class="heading-65"><a href="/resume" class="link-10">View Resume</a></h5>
                </div>
              </div>
              <div class="div-block-156">
                <div class="text-block-110">E-mail me?</div>
                <div class="div-block-159">
                  <img src="/assets/images/arrow_right_icon.svg" loading="lazy" alt="" class="image-96" />
                  <h5 class="heading-65"><a href="mailto:emilybackes.design@gmail.com?subject=Let's Chat!" class="link-8">emilybackes.design@gmail.com</a></h5>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

  </div><!-- /.pillars-page -->

</PageLayout>

<style>
  /* ── Page shell — light/cream "5 Pillars" design system (Lexend + Inconsolata) ── */
  .pillars-page {
    background-color: var(--5p-bg);
    color: var(--midnight-blue-500);
    font-family: 'Inconsolata', monospace;
    overflow-x: clip; /* contain the intentional 110%-width balance row */
  }

  /* All Webflow-style section containers center at max 1440 (parity with .w-container) */
  .pillars-page [class*="__container"] {
    max-width: 1440px;
    margin-left: auto;
    margin-right: auto;
  }

  /* Shared pull-quote treatment across all pillars */
  .pillars-page .text-block-112 {
    margin-top: var(--def-spacer);
    margin-bottom: var(--def-spacer);
    padding: var(--md-spacer);
    border-left: 4px solid var(--5p-ballad);
    color: var(--midnight-blue-500);
    font-family: 'Lexend', sans-serif;
    font-size: var(--h5);
    line-height: var(--h4);
  }

  /* ═══════════════ HERO ═══════════════ */
  ._5p_hero__section { margin-top: var(--def-spacer); margin-bottom: var(--lg-spacer); }
  ._5p_hero__container { max-width: 1440px; }
  ._5p_hero__wrapper {
    margin: var(--def-spacer);
    background-color: var(--toe-bean-pink-100);
    border-radius: 8px;
    flex-flow: column;
    display: flex;
  }
  .hero_heading__wrapper {
    margin-top: var(--lg-spacer);
    margin-bottom: var(--lg-spacer);
    padding: var(--def-spacer) var(--lg-spacer);
    grid-column-gap: var(--def-spacer);
    grid-row-gap: var(--def-spacer);
    justify-content: space-between;
    align-items: stretch;
    display: flex;
  }
  .heading-62 {
    color: var(--5p-cold);
    font-family: 'Lexend', sans-serif;
    font-size: var(--text-xl);
    text-align: left;
    margin-top: 0;
    margin-bottom: 0;
    font-weight: 600;
    line-height: 4rem;
  }
  .div-block-146 { margin-bottom: var(--xxs-spacer); align-items: flex-end; display: flex; }
  .text-block-107 { color: var(--midnight-blue-500); font-size: var(--text-body); line-height: var(--h5); }
  .hero_card__wrapper {
    grid-column-gap: 0rem;
    grid-row-gap: 0rem;
    flex-flow: row;
    justify-content: space-around;
    align-items: stretch;
    max-width: 1440px;
    height: 24rem;
    display: flex;
  }
  .pillar_card__wrapper._5p_ethics_card {
    background-color: #dfb1b600; border-radius: 0; justify-content: space-between;
    width: 20%; height: 24rem; padding: 1rem; position: relative; overflow: hidden;
  }
  .pillar_card__wrapper._5p_collab__card,
  .pillar_card__wrapper._5p_trans__card,
  .pillar_card__wrapper._5p_balance__card,
  .pillar_card__wrapper._5p_happiness__card {
    border-radius: 0; justify-content: space-between;
    width: 20%; height: 24rem; position: relative; overflow: hidden;
  }
  .pillar_card__wrapper._5p_collab__card { background-color: #cd899e00; }
  .pillar_card__wrapper._5p_trans__card { background-color: #a6427c00; }
  .pillar_card__wrapper._5p_balance__card { background-color: #23427200; }
  .pillar_card__wrapper._5p_happiness__card { background-color: #13204300; }
  ._5p_pillar_one { margin-left: auto; margin-right: auto; position: absolute; inset: 50% 0% 0%; }
  ._5p_pillar_two { position: absolute; inset: 30% 0% 0%; }
  ._5p_pillar_three { position: absolute; inset: 15% 0% 0%; }
  ._5p_pillar_four { position: absolute; inset: 45% 0% 0%; }
  ._5p_pillar_five { position: absolute; inset: 30% 0% 0%; }
  ._5p_hero__post__stats {
    margin-right: var(--md-spacer); margin-left: var(--md-spacer);
    justify-content: flex-end; align-items: center; display: flex;
  }
  .read_time__wrapper { margin-right: var(--def-spacer); justify-content: flex-start; align-items: center; display: flex; }
  .image-86 { width: 16px; margin-right: var(--xs-spacer); }
  .text-block-108 { color: var(--navy-blue-500); font-size: var(--text-sm); }

  @media screen and (min-width: 1440px) {
    .hero_card__wrapper { grid-column-gap: var(--md-spacer); grid-row-gap: var(--md-spacer); justify-content: center; }
  }
