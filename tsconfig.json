{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*"],
  // Verbatim 1:1 Webflow ports contain third-party inline SVG + animation scripts
  // that aren't meaningfully type-checkable as TSX; `npm run build` still validates them.
  "exclude": [
    "dist",
    "src/pages/case-study/sage-designing-an-ai-powered-chatbot.astro",
    "src/pages/case-study/folsom-psychology.astro",
    "src/pages/case-study/subscription-cancellation.astro"
  ]
}
